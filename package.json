{
  "name": "@arcisprotocol/custos",
  "version": "0.1.0",
  "description": "CUSTOS \u2014 The Keeper of the Citadel. Autonomous DeFi agent for Arcis Protocol.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean --external spectrum-ts --external @x402/axios --external @x402/evm --external axios",
    "acp": "tsx src/acp/provider.ts",
    "acp:offerings": "tsx src/acp/emit-offerings.ts",
    "graduator": "tsx src/graduator/index.ts",
    "spectrum": "tsx --env-file-if-exists=.env src/spectrum-server.ts",
    "acp:register": "bash scripts/register-offerings.sh",
    "prospect": "tsx src/prospector/index.ts",
    "outreach": "tsx src/outreach/index.ts",
    "campaign": "npm run prospect && npm run outreach",
    "campaign:auto": "tsx src/campaign/scheduler.ts",
    "outreach:webhook": "tsx src/outreach/webhook.ts"
  },
  "dependencies": {
    "@x402/axios": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "spectrum-ts": "^8.2.1"
  }
}
