
# ── Agentic Treasury (CUSTOS accumulation → vault → credit) ──
# Off + dry-run by default. See TREASURY.md for the go-live checklist.
TREASURY_ENABLED=false
TREASURY_DRY_RUN=true
VIRTUALS_BONDING_ADDRESS=          # Virtuals Bonding singleton on Base (verified by preflight)
TREASURY_PER_BUY_VIRTUAL=10        # $VIRTUAL per accumulation buy
TREASURY_BUDGET_VIRTUAL=100        # lifetime $VIRTUAL budget cap
TREASURY_DAILY_CAP_VIRTUAL=50      # rolling 24h spend cap
TREASURY_INTERVAL_MS=3600000       # min spacing between buys (1h)
TREASURY_MAX_SLIPPAGE_BPS=300      # min-tokens-out floor (3%)
TREASURY_AUTO_DEPOSIT=true         # deposit acquired $CUSTOS into raCUSTOS
TREASURY_STOP_AT_GRADUATION=true
