
# ── Agentic Treasury (CUSTOS accumulation → vault → credit) ──
# Off + dry-run by default. See TREASURY.md for the go-live checklist.
TREASURY_ENABLED=false
TREASURY_DRY_RUN=true
VIRTUALS_BONDING_ADDRESS=          # Virtuals Bonding singleton on Base (verified by preflight)
TREASURY_PER_BUY_VIRTUAL=10        # $VIRTUAL per accumulation buy
TREASURY_BUDGET_VIRTUAL=100        # lifetime $VIRTUAL budget cap
TREASURY_DAILY_CAP_VIRTUAL=50      # rolling 24h spend cap
TREASURY_INTERVAL_MS=3600000       # min spacing between buys (1h)
TREASURY_MAX_SLIPPAGE_BPS=300      # min-tokens-out floor (3%)
TREASURY_AUTO_DEPOSIT=true         # deposit acquired $CUSTOS into raCUSTOS
TREASURY_STOP_AT_GRADUATION=true

# ── Path B: ACP earner (CUSTOS sells services → USDC → Arcis) ──
# Provider process (npm run acp). See ACP.md for the full runbook.
ACP_BUILDER_CODE=                  # bc-... from app.virtuals.io/acp/new
ACP_WALLET_ADDRESS=                # the EconomyOS agent wallet
ACP_MODE=privy                     # privy (non-custodial) | local (raw key)
ACP_PRIVY_WALLET_ID=               # privy mode
ACP_SIGNER_PRIVATE_KEY=            # privy signer delegate OR local key
# Earnings → Arcis bridge (runs in the keeper loop; off + dry-run by default)
ACP_BRIDGE_ENABLED=false
ACP_BRIDGE_DRY_RUN=true
ACP_BRIDGE_MIN_USDC=5              # only sweep once earnings clear this
ACP_BRIDGE_RESERVE_USDC=0          # keep this much USDC liquid
# Agent Compute (the $200 inference credits fund CUSTOS's brain)
VIRTUALS_API_KEY=                  # from the agent Compute settings
# VIRTUALS_COMPUTE_BASE_URL=https://compute.virtuals.io/v1
# Treasury Management (fund-transfer: CUSTOS manages other agents' USDC)
ACP_MGMT_ENABLED=false
ACP_MGMT_DRY_RUN=true
ACP_MGMT_MAX_PER_CLIENT_USDC=1000  # per-position principal cap
ACP_MGMT_MAX_AUM_USDC=10000        # total assets-under-management cap
ACP_MGMT_RESERVE_USDC=0            # USDC kept liquid, never deployed
